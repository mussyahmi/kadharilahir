rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Invitations: public read, owner write
    match /invitations/{invitationId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      // RSVPs: public read, anyone can create, owner can delete
      match /rsvps/{rsvpId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if request.auth != null
          && get(/databases/$(database)/documents/invitations/$(invitationId)).data.ownerId == request.auth.uid;
      }
    }

    // Slugs: public read, authenticated write
    match /slugs/{slug} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow update: if false;
    }
  }
}
